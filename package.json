{
  "name": "ble-calculator-desktop",
  "version": "0.1.0",
  "description": "Cross-platform Electron calculator sync app backed by a Rust napi-rs core.",
  "private": true,
  "author": {
    "name": "Zheng Qing Sia",
    "email": "yoyoinane@gmail.com"
  },
  "main": "dist/src/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "npm run build:native:optional && npm run build:app",
    "build:app": "tsc -p tsconfig.json && vite build",
    "build:native": "node scripts/build-native.mjs",
    "build:native:optional": "node scripts/build-native-optional.mjs",
    "package": "node scripts/package-platforms.mjs",
    "package:current": "node scripts/package-platforms.mjs current",
    "package:all": "node scripts/package-platforms.mjs all",
    "release:all": "gh workflow run release.yml",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run --config vitest.config.mts"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.3",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^26.15.3",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "typescript": "^5.7.2",
    "vite": "^6.4.3",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.5"
  }
}
